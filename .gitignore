# Public repository allowlist.
# Everything is private by default except the static gallery, public works data, and local tooling under new/.

*

!.gitignore
!new/

new/*
!new/AGENTS.md
!new/README.md
!new/package.json
!new/package-lock.json
!new/vite.config.js
!new/index.html
!new/src/
!new/src/**
!new/tools/
!new/tools/**
!new/works/
!new/works/**

# Local/generated state inside the public project root.
new/node_modules/
new/dist/
new/.vite/
new/*.log

# Closed source local inputs.
new/todo/
new/prototype/
new/research-materials/
